# ================================
# Petit Bac — Config Maître du Jeu
# ================================

# URL publique du frontend déployé sur Vercel (sans slash de fin).
# Sert à configurer les politiques CORS du backend.
FRONTEND_URL=https://petit-bac.vercel.app

# Jeton d'authentification Ngrok (https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_token_here

# Port exposé par le backend à l'intérieur du réseau Docker.
# Le tunnel Ngrok le relaiera automatiquement.
BACKEND_PORT=4000

# (Optionnel) Jeton partagé entre le MJ et le frontend pour revendiquer le rôle de MJ.
# Si vide, le premier client ayant ouvert l'interface MJ devient hôte.
MJ_SECRET=
